rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }
    // Safe when user doc doesn't exist yet (e.g. first sign-in before profile is created)
    function getUserRole() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid))
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role
        : 'staff';
    }
    function isAdmin() {
      return isSignedIn() && getUserRole() == 'admin';
    }
    function isManagerOrAdmin() {
      return isSignedIn() && (getUserRole() == 'admin' || getUserRole() == 'manager');
    }
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && (request.auth.uid == userId || getUserRole() == 'admin');
      allow update, delete: if isAdmin();
    }
    match /fuelTypes/{id} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }
    match /tanks/{id} {
      allow read, create: if isSignedIn();
      allow update, delete: if isAdmin();
    }
    match /nozzles/{id} {
      allow read, create: if isSignedIn();
      allow update, delete: if isAdmin();
    }
    match /meterReadings/{id} {
      allow read, create: if isSignedIn();
      allow update, delete: if isAdmin();
    }
    match /tankerDeliveries/{id} {
      allow read, create: if isSignedIn();
      allow update, delete: if isAdmin();
    }
    match /payments/{id} {
      allow read, create: if isSignedIn();
      allow update, delete: if isAdmin();
    }
    match /dipEntries/{id} {
      allow read, create: if isSignedIn();
      allow update, delete: if isAdmin();
    }
    match /expenses/{id} {
      allow read, create: if isSignedIn();
      allow update, delete: if isAdmin();
    }
    match /shifts/{id} {
      allow read, create: if isSignedIn();
      allow update, delete: if isAdmin();
    }
    match /notifications/{id} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }
    match /auditLogs/{id} {
      allow read: if isAdmin();
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }
  }
}
