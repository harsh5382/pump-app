rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }
    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }
    function isAdmin() {
      return isSignedIn() && getUserRole() == 'admin';
    }
    function isManagerOrAdmin() {
      return isSignedIn() && (getUserRole() == 'admin' || getUserRole() == 'manager');
    }
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && (request.auth.uid == userId || (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'));
      allow update, delete: if isAdmin();
    }
    match /fuelTypes/{id} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }
    match /tanks/{id} {
      allow read, write: if isSignedIn();
    }
    match /nozzles/{id} {
      allow read, write: if isSignedIn();
    }
    match /meterReadings/{id} {
      allow read, write: if isSignedIn();
    }
    match /tankerDeliveries/{id} {
      allow read, write: if isSignedIn();
    }
    match /payments/{id} {
      allow read, write: if isSignedIn();
    }
    match /dipEntries/{id} {
      allow read, write: if isSignedIn();
    }
    match /expenses/{id} {
      allow read, write: if isSignedIn();
    }
    match /shifts/{id} {
      allow read, write: if isSignedIn();
    }
    match /notifications/{id} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }
    match /auditLogs/{id} {
      allow read: if isAdmin();
      allow create: if isSignedIn();
      allow update, delete: if false;
    }
  }
}
